# 1. Берем за основу готовый Python
FROM python:3.10-slim

# 2. Создаем внутри контейнера папку, где будет жить твой код
WORKDIR /app

# 3. Копируем файл с библиотеками (который ты сделал)
COPY requirements.txt .

# 4. Устанавливаем все нужные библиотеки (это автоматика)
RUN pip install --no-cache-dir -r requirements.txt

# 5. Копируем весь твой код из папки backend внутрь контейнера
COPY . .

# 6. Указываем команду, которую нужно запустить для старта сервера
CMD ["uvicorn", "main:app", "--host", "0.0.0.0", "--port", "8000"]